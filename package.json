{
  "name": "retrobuzz",
  "version": "0.1.0",
  "private": true,
  "description": "RetroBuzz — Blind test musical interactif, esthétique rétro-arcade",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:*",
    "dev:api": "npm --workspace @retrobuzz/api run dev",
    "dev:web": "npm --workspace @retrobuzz/web run dev",
    "build": "npm-run-all build:*",
    "build:api": "npm --workspace @retrobuzz/api run build",
    "build:web": "npm --workspace @retrobuzz/web run build",
    "db:generate": "npm --workspace @retrobuzz/api run db:generate",
    "db:migrate": "npm --workspace @retrobuzz/api run db:migrate",
    "db:seed": "npm --workspace @retrobuzz/api run db:seed",
    "db:studio": "npm --workspace @retrobuzz/api run db:studio",
    "start": "bash scripts/start.sh",
    "stop": "bash scripts/stop.sh",
    "restart": "bash scripts/stop.sh && bash scripts/start.sh",
    "status": "bash scripts/status.sh",
    "logs": "bash scripts/logs.sh",
    "logs:api": "tail -f logs/api.log",
    "logs:web": "tail -f logs/web.log"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
